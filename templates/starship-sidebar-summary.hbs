<div class="sw5e-starship-sidebar-summary-inner">
  <header class="sw5e-starship-sidebar-summary-header">
    <span class="sw5e-starship-sidebar-summary-kicker">Starship Systems</span>
  </header>

  <div class="sw5e-starship-sidebar-summary-list">
    {{#each entries}}
      <article class="sw5e-starship-sidebar-summary-entry{{#if sidebarDerivedRow}} sw5e-starship-sidebar-summary-entry--derived{{/if}}">
        <span class="sw5e-starship-sidebar-summary-label">{{label}}</span>

        {{#if ../sidebarQuickEdit}}
          {{#if sidebarTier}}
            <div class="sw5e-starship-sidebar-quick sw5e-starship-sidebar-quick--tier">
              <input
                type="number"
                class="sw5e-starship-sidebar-input"
                data-sw5e-system-path="system.details.tier"
                value="{{../systemsCore.tierValue}}"
                min="0"
                step="1"
                inputmode="numeric"
                data-dtype="Number"
                aria-label="{{label}}"
              />
            </div>
          {{/if}}

          {{#if sidebarSize}}
            <div class="sw5e-starship-sidebar-quick sw5e-starship-sidebar-quick--size">
              <select class="sw5e-starship-sidebar-select" data-sw5e-system-path="system.traits.size" data-dtype="String" aria-label="{{label}}">
                {{#each ../systemsCore.sizeOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          {{/if}}

          {{#if sidebarHull}}
            <div class="sw5e-starship-sidebar-quick sw5e-starship-sidebar-quick--pair" role="group" aria-label="{{label}}">
              <input
                type="number"
                class="sw5e-starship-sidebar-input"
                data-sw5e-system-path="system.attributes.hp.value"
                value="{{../systemsCore.hullPointsValue}}"
                min="0"
                step="1"
                inputmode="numeric"
                data-dtype="Number"
                title="{{../systemsCore.labels.hullCurrent}}"
              />
              <span class="sw5e-starship-sidebar-quick-sep" aria-hidden="true">/</span>
              <input
                type="number"
                class="sw5e-starship-sidebar-input"
                data-sw5e-system-path="system.attributes.hp.max"
                value="{{../systemsCore.hullPointsMax}}"
                min="0"
                step="1"
                inputmode="numeric"
                data-dtype="Number"
                title="{{../systemsCore.labels.hullMax}}"
              />
            </div>
          {{/if}}

          {{#if sidebarShield}}
            <div class="sw5e-starship-sidebar-quick sw5e-starship-sidebar-quick--pair" role="group" aria-label="{{label}}">
              <input
                type="number"
                class="sw5e-starship-sidebar-input"
                data-sw5e-system-path="system.attributes.hp.temp"
                value="{{../systemsCore.shieldPointsTemp}}"
                min="0"
                step="1"
                inputmode="numeric"
                data-dtype="Number"
                title="{{../systemsCore.labels.shieldCurrent}}"
              />
              <span class="sw5e-starship-sidebar-quick-sep" aria-hidden="true">/</span>
              <input
                type="number"
                class="sw5e-starship-sidebar-input"
                data-sw5e-system-path="system.attributes.hp.tempmax"
                value="{{../systemsCore.shieldPointsTempMax}}"
                min="0"
                step="1"
                inputmode="numeric"
                data-dtype="Number"
                title="{{../systemsCore.labels.shieldMax}}"
              />
            </div>
          {{/if}}

          {{#if sidebarShowValueOnly}}
            <strong class="sw5e-starship-sidebar-summary-value{{#if sidebarDerivedRow}} sw5e-starship-sidebar-summary-value--derived{{/if}}">{{value}}</strong>
          {{/if}}

        {{else}}
          <strong class="sw5e-starship-sidebar-summary-value{{#if sidebarDerivedRow}} sw5e-starship-sidebar-summary-value--derived{{/if}}">{{value}}</strong>
        {{/if}}

        {{#if note}}
          <span class="sw5e-starship-sidebar-summary-note">{{note}}</span>
        {{/if}}
      </article>
    {{/each}}
  </div>
</div>

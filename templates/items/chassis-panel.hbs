<section class="sw5e-chassis-panel" aria-label="{{localize "SW5E.Chassis.SectionTitle"}}">
	<header class="sw5e-chassis-header">
		<h3 class="sw5e-chassis-title">{{localize "SW5E.Chassis.SectionTitle"}}</h3>
	</header>

	{{#unless chassisEnabled}}
		<p class="sw5e-chassis-hint">{{localize "SW5E.Chassis.EnableHint"}}</p>
		{{#if isEditable}}
			<button type="button" class="sw5e-chassis-btn sw5e-chassis-btn--primary" data-chassis-action="enable">
				<i class="fas fa-microchip" aria-hidden="true"></i> {{localize "SW5E.Chassis.Enable"}}
			</button>
		{{/if}}
	{{else}}

		{{#if chassisSlotOverflow}}
			<div class="sw5e-chassis-slot-overflow" role="status">
				<strong class="sw5e-chassis-slot-overflow-title">{{localize "SW5E.Chassis.SlotOverflowTitle"}}</strong>
				<p class="sw5e-chassis-slot-overflow-body">{{localize "SW5E.Chassis.SlotOverflowWarning"}}</p>
			</div>
		{{/if}}

		<dl class="sw5e-chassis-summary">
			<div class="sw5e-chassis-kv">
				<dt>{{localize "SW5E.Chassis.LabelSlots"}}</dt>
				<dd><span class="sw5e-chassis-slots-stat">{{slotsUsedTotal}}</span></dd>
			</div>
			<div class="sw5e-chassis-kv">
				<dt>{{localize "SW5E.Chassis.LabelType"}}</dt>
				<dd>{{chassisTypeLabel}}</dd>
			</div>
			<div class="sw5e-chassis-kv">
				<dt>{{localize "SW5E.Chassis.LabelRarity"}}</dt>
				<dd>{{chassisRarityLabel}}</dd>
			</div>
			<div class="sw5e-chassis-kv sw5e-chassis-kv--wide">
				<dt>{{localize "SW5E.Chassis.LabelRules"}}</dt>
				<dd class="sw5e-chassis-rules-value {{#if hasRulesOverride}}is-override{{/if}}">
					<div class="sw5e-chassis-rules-primary">{{rulesModePrimaryText}}</div>
					{{#if rulesModeSecondaryText}}
						<div class="sw5e-chassis-rules-secondary subdued">{{rulesModeSecondaryText}}</div>
					{{/if}}
				</dd>
			</div>
			<div class="sw5e-chassis-kv sw5e-chassis-kv--wide">
				<dt>{{localize "SW5E.Chassis.LabelAttunement"}}</dt>
				<dd class="sw5e-chassis-subdued">{{attunementText}}</dd>
			</div>
		</dl>
		<p class="sw5e-chassis-slots-detail subdued">{{slotsSummaryText}}</p>
		<p class="sw5e-chassis-section-intro subdued">{{localize "SW5E.Chassis.SlotsBudgetHelp"}}</p>

		{{#if isEditable}}
			<div class="sw5e-chassis-rules-field">
				<label class="sw5e-chassis-rules-field-label" for="sw5e-chassis-rules-{{rulesSelectId}}">{{localize "SW5E.Chassis.RulesModeFieldLabel"}}</label>
				<select id="sw5e-chassis-rules-{{rulesSelectId}}" class="sw5e-chassis-select" data-chassis-field="rulesMode" aria-describedby="sw5e-chassis-rules-hint-{{rulesSelectId}}">
					{{#each rulesModeOptions}}
						<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
					{{/each}}
				</select>
				<p id="sw5e-chassis-rules-hint-{{rulesSelectId}}" class="sw5e-chassis-field-hint subdued">{{localize "SW5E.Chassis.RulesModeFieldHint"}}</p>
			</div>
		{{/if}}

		<div class="sw5e-chassis-slots-core">
			<h4 class="sw5e-chassis-section-title">{{localize "SW5E.Chassis.SlotLayout"}}</h4>
			<p class="sw5e-chassis-section-intro subdued">{{localize "SW5E.Chassis.SlotMapHelp"}}</p>

			<div class="sw5e-chassis-slot-group">
				<div class="sw5e-chassis-slot-group-head">{{localize "SW5E.Chassis.SlotGroupBase"}}</div>
				<ul class="sw5e-chassis-slot-grid">
					{{#each slotRowsBase}}
						<li class="sw5e-chassis-slot-cell {{#if entries.length}}is-occupied{{else}}is-empty{{/if}}">
							<span class="sw5e-chassis-slot-label">{{slotLabelDisplay}}</span>
							{{#if entries.length}}
								<div class="sw5e-chassis-slot-body">
									{{#each entries}}
										<span class="sw5e-chassis-slot-mod">{{snapshot.name}}</span>
										<span class="sw5e-chassis-slot-cost subdued">{{localize "SW5E.Chassis.SlotCostShort"}} {{slotCost}}</span>
									{{/each}}
								</div>
							{{else}}
								<span class="sw5e-chassis-slot-empty subdued">{{localize "SW5E.Chassis.SlotEmpty"}}</span>
								{{#if ../isEditable}}
									<button type="button" class="sw5e-chassis-btn sw5e-chassis-btn--slot-install" data-chassis-action="install-workflow" data-chassis-slot-kind="{{kind}}" data-chassis-slot-index="{{index}}" {{#if slotSemantic}}data-chassis-slot-role="{{slotSemantic}}"{{/if}}>
										<i class="fas fa-plus" aria-hidden="true"></i> {{localize "SW5E.Chassis.InstallHere"}}
									</button>
								{{/if}}
							{{/if}}
						</li>
					{{/each}}
				</ul>
			</div>

			{{#if slotRowsAugment.length}}
				<div class="sw5e-chassis-slot-group">
					<div class="sw5e-chassis-slot-group-head">{{localize "SW5E.Chassis.SlotGroupAugment"}}</div>
					<ul class="sw5e-chassis-slot-grid">
						{{#each slotRowsAugment}}
							<li class="sw5e-chassis-slot-cell {{#if entries.length}}is-occupied{{else}}is-empty{{/if}}">
								<span class="sw5e-chassis-slot-label">{{slotLabelDisplay}}</span>
								{{#if entries.length}}
									<div class="sw5e-chassis-slot-body">
										{{#each entries}}
											<span class="sw5e-chassis-slot-mod">{{snapshot.name}}</span>
											<span class="sw5e-chassis-slot-cost subdued">{{localize "SW5E.Chassis.SlotCostShort"}} {{slotCost}}</span>
										{{/each}}
									</div>
								{{else}}
									<span class="sw5e-chassis-slot-empty subdued">{{localize "SW5E.Chassis.SlotEmpty"}}</span>
									{{#if ../isEditable}}
										<button type="button" class="sw5e-chassis-btn sw5e-chassis-btn--slot-install" data-chassis-action="install-workflow" data-chassis-slot-kind="{{kind}}" data-chassis-slot-index="{{index}}" {{#if slotSemantic}}data-chassis-slot-role="{{slotSemantic}}"{{/if}}>
											<i class="fas fa-plus" aria-hidden="true"></i> {{localize "SW5E.Chassis.InstallHere"}}
										</button>
									{{/if}}
								{{/if}}
							</li>
						{{/each}}
					</ul>
				</div>
			{{/if}}
		</div>

		<div class="sw5e-chassis-installed">
			{{#if installedRows.length}}
				<details class="sw5e-chassis-installed-details">
					<summary class="sw5e-chassis-installed-summary">{{installedLogSummaryText}}</summary>
					<div class="sw5e-chassis-installed-details-body">
						<p class="sw5e-chassis-section-intro subdued">{{localize "SW5E.Chassis.InstalledListHelp"}}</p>
						<ul class="sw5e-chassis-mod-list">
							{{#each installedRows}}
								<li class="sw5e-chassis-mod-card">
									<div class="sw5e-chassis-mod-title">{{name}}</div>
									<div class="sw5e-chassis-mod-tags">
										<span class="sw5e-chassis-tag">{{rarityDisplay}}</span>
										<span class="sw5e-chassis-tag">{{slotPositionLabel}}</span>
										<span class="sw5e-chassis-tag">{{localize "SW5E.Chassis.SlotCostShort"}} {{slotCost}}</span>
									</div>
									<div class="sw5e-chassis-mod-foot subdued">{{installedTime}}</div>
								</li>
							{{/each}}
						</ul>
					</div>
				</details>
			{{else}}
				<p class="sw5e-chassis-empty subdued">{{localize "SW5E.Chassis.NoMods"}}</p>
			{{/if}}
		</div>

		{{#if isEditable}}
			<footer class="sw5e-chassis-actions">
				<div class="sw5e-chassis-actions-group sw5e-chassis-actions-group--normal">
					<div class="sw5e-chassis-actions-heading">{{localize "SW5E.Chassis.ActionsNormalHeading"}}</div>
					<div class="sw5e-chassis-actions-row sw5e-chassis-actions-row--primary">
						<button type="button" class="sw5e-chassis-btn sw5e-chassis-btn--primary" data-chassis-action="install-workflow">
							<i class="fas fa-plus" aria-hidden="true"></i> {{localize "SW5E.Chassis.ActionInstall"}}
						</button>
					</div>
					<div class="sw5e-chassis-actions-row sw5e-chassis-actions-row--secondary">
						<button type="button" class="sw5e-chassis-btn" data-chassis-action="remove-workflow">
							<i class="fas fa-minus" aria-hidden="true"></i> {{localize "SW5E.Chassis.ActionRemove"}}
						</button>
						<button type="button" class="sw5e-chassis-btn" data-chassis-action="upgrade-workflow" {{#unless canUpgradeChassis}}disabled{{/unless}}>
							<i class="fas fa-arrow-up" aria-hidden="true"></i> {{localize "SW5E.Chassis.ActionUpgrade"}}
						</button>
					</div>
				</div>
				<div class="sw5e-chassis-actions-divider" role="presentation"></div>
				<div class="sw5e-chassis-actions-group sw5e-chassis-actions-group--danger">
					<div class="sw5e-chassis-actions-heading sw5e-chassis-actions-heading--danger">{{localize "SW5E.Chassis.ActionsDangerHeading"}}</div>
					<p class="sw5e-chassis-actions-hint subdued">{{localize "SW5E.Chassis.ActionsDangerHint"}}</p>
					<div class="sw5e-chassis-actions-row sw5e-chassis-actions-row--utility">
						<button type="button" class="sw5e-chassis-btn sw5e-chassis-btn--quiet" data-chassis-action="disable">
							<i class="fas fa-power-off" aria-hidden="true"></i> {{localize "SW5E.Chassis.Disable"}}
						</button>
						<button type="button" class="sw5e-chassis-btn sw5e-chassis-btn--danger" data-chassis-action="remove-data">
							<i class="fas fa-trash" aria-hidden="true"></i> {{localize "SW5E.Chassis.RemoveData"}}
						</button>
					</div>
				</div>
			</footer>
		{{/if}}
	{{/unless}}
</section>

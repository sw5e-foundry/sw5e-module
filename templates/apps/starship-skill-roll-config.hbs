<form class="sw5e-starship-skill-roll-form">
  <p class="notes">{{formulaLabel}}</p>

  <div class="form-group">
    <label>{{bonusLabel}}</label>
    <input type="text" name="bonus" value="" placeholder="{{bonusPlaceholder}}">
  </div>

  <fieldset>
    <legend>{{configurationLabel}}</legend>

    <div class="form-group">
      <label>{{abilityLabel}}</label>
      <select name="ability">
        {{#each abilityOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>

    <div class="form-group">
      <label>{{rollModeLabel}}</label>
      <select name="rollMode">
        {{#each rollModeOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
  </fieldset>

  {{#if systemDamageNote}}
  <p class="notes">{{systemDamageNote}}</p>
  {{/if}}

  <footer class="sheet-footer flexrow">
    <button type="button" data-advantage-mode="{{advantageMode}}" {{#if isDefaultAdvantage}}autofocus{{/if}}>{{advantageLabel}}</button>
    {{#unless forcedAdvantage}}
    <button type="button" data-advantage-mode="{{normalMode}}" {{#if isDefaultNormal}}autofocus{{/if}}>{{normalLabel}}</button>
    <button type="button" data-advantage-mode="{{disadvantageMode}}" {{#if isDefaultDisadvantage}}autofocus{{/if}}>{{disadvantageLabel}}</button>
    {{/unless}}
  </footer>
</form>

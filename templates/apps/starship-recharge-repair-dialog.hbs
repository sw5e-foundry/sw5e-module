<section class="flexcol">
  <div class="note info">{{hint}}</div>

  {{#if fields.length}}
  <fieldset>
    <legend>{{localize "DND5E.REST.Configuration"}}</legend>
    {{> "dnd5e.fieldlist" fields }}
  </fieldset>
  {{/if}}

  {{#if hullDice}}
  {{#if hullDice.canRoll}}
  <fieldset>
    <legend>{{localize "SW5E.StarshipSheet.RepairHullDiceLegend"}}</legend>
    <div class="form-fields">
      <select name="denom">
        {{ selectOptions hullDice.options selected=hullDice.denomination }}
      </select>
      <button type="button" class="dice-button" data-action="rollHull" data-tooltip
              aria-label="{{localize 'DND5E.Roll'}}">
        <i class="fa-solid fa-dice-d20" inert></i>
      </button>
    </div>
    {{ formField autoSpendField name="autoHD" value=config.autoHD input=inputs.createCheckboxInput rootId=partId }}
  </fieldset>
  {{else}}
  <div class="note warn">{{localize "SW5E.RechargeRepairNoHD"}}</div>
  {{/if}}
  {{/if}}
</section>

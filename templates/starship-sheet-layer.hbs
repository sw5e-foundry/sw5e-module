{{!-- Core tab: operational overview (skills, crew, fuel, routing). Weapons, Equipment, and cargo on Inventory; Actions, Modifications, Systems on Features. --}}
{{#*inline "sw5e-sotg-item-row"}}
{{!-- Cargo-style row: primary strip PLAY=use/post, EDIT=edit sheet; icon controls like inventory `controls.hbs`. --}}
<li class="item sw5e-starship-item-row sw5e-starship-item-row--sotg" data-item-id="{{id}}" data-item-name="{{name}}"{{#if sotgPanel}} data-sotg-panel="{{sotgPanel}}"{{/if}}>
  <div class="item-row sw5e-starship-item-row--sotg-inner">
    <button
      type="button"
      class="item-name item-action item-tooltip unbutton sw5e-starship-item-name-cell{{#unless @root.sotgSheetEditMode}} rollable{{/unless}}"
      aria-label="{{name}}"
    >
      {{#if img}}
      <img class="item-image gold-icon sw5e-starship-item-image" src="{{img}}" alt="" draggable="false" />
      {{else}}
      <span class="item-image gold-icon sw5e-starship-item-icon-fallback" aria-hidden="true"><i class="fas fa-cube"></i></span>
      {{/if}}
      <div class="name name-stacked">
        <span class="title sw5e-starship-item-name">{{name}}</span>
        {{#if meta}}
        <span class="subtitle sw5e-starship-item-meta">{{meta}}</span>
        {{/if}}
      </div>
    </button>
    {{#if ../showEconomy}}
    <div class="sw5e-starship-item-economy" aria-hidden="true">
      <span class="sw5e-starship-item-stat sw5e-starship-item-stat--price{{#unless priceLabel}} sw5e-starship-item-stat--empty{{/unless}}" title="Price">{{#if priceLabel}}{{priceLabel}}{{else}}&nbsp;{{/if}}</span>
      <span class="sw5e-starship-item-stat sw5e-starship-item-stat--weight{{#unless weightLabel}} sw5e-starship-item-stat--empty{{/unless}}" title="Weight">{{#if weightLabel}}{{weightLabel}}{{else}}&nbsp;{{/if}}</span>
    </div>
    {{/if}}
    <div class="item-detail item-controls always-visible sw5e-starship-item-actions">
      {{#if ../supportsSheetNavigation}}
      <button
        type="button"
        class="unbutton config-button item-control item-action always-interactive"
        data-sw5e-action="focus-item"
        data-item-id="{{id}}"
        data-tab="{{defaultTab}}"
        data-tooltip
        aria-label="{{@root.sotgFindInSheetAria}}"
      >
        <i class="fa-solid fa-magnifying-glass" inert></i>
      </button>
      {{/if}}
      <span class="sw5e-starship-sotg-controls-edit">
        <button
          type="button"
          class="unbutton config-button item-control item-action"
          data-sw5e-action="edit-item"
          data-item-id="{{id}}"
          data-tooltip
          aria-label="{{ localize "DND5E.ItemEdit" }}"
        >
          <i class="fa-solid fa-pen-to-square" inert></i>
        </button>
        <button
          type="button"
          class="unbutton config-button item-control item-action sw5e-starship-item-button-danger"
          data-sw5e-action="delete-item"
          data-item-id="{{id}}"
          data-tooltip
          aria-label="{{ localize "DND5E.ItemDelete" }}"
        >
          <i class="fa-solid fa-trash" inert></i>
        </button>
      </span>
      <button
        type="button"
        class="unbutton config-button item-control always-interactive"
        data-context-menu
        aria-label="{{@root.sotgContextMenuAria}}"
      >
        <i class="fa-solid fa-ellipsis-vertical" inert></i>
      </button>
    </div>
  </div>
</li>
{{/inline}}

{{#*inline "sw5e-starship-crew-management"}}
<div class="sw5e-starship-crew-command">
  <div class="sw5e-starship-crew-status" aria-live="polite">
    <span class="sw5e-starship-crew-status-label">Assigned crew</span>
    <strong class="sw5e-starship-crew-status-value">{{crew.roster.length}}</strong>
  </div>
</div>

<div class="sw5e-starship-crew-operations">
  {{#if crew.roster.length}}
    <div class="sw5e-starship-item-list sw5e-starship-crew-roster">
      {{#each crew.roster}}
        <article class="sw5e-starship-item-row sw5e-starship-crew-row{{#if active}} sw5e-crew-active{{/if}}">
          <div class="sw5e-starship-item-main">
            <img class="sw5e-starship-item-image" src="{{img}}" alt="{{name}}" />
            <div class="sw5e-starship-item-copy">
              <strong class="sw5e-starship-item-name">{{name}}</strong>
              <div class="sw5e-crew-badges">
                {{#if isPilot}}<span class="sw5e-crew-badge sw5e-crew-badge-pilot">Pilot</span>{{/if}}
                {{#if active}}<span class="sw5e-crew-badge sw5e-crew-badge-active">Active</span>{{/if}}
                {{#unless isPilot}}{{#if isCrew}}<span class="sw5e-crew-badge">Crew</span>{{/if}}{{/unless}}
                {{#if isPassenger}}<span class="sw5e-crew-badge">Passenger</span>{{/if}}
              </div>
            </div>
          </div>
          <div class="sw5e-starship-item-actions sw5e-starship-crew-row-actions">
            {{#if isPilot}}
              <button
                type="button"
                class="sw5e-starship-item-button sw5e-starship-crew-icon-button"
                data-sw5e-crew-command="undeploy-pilot"
                data-actor-uuid="{{uuid}}"
                title="{{ localize "SW5E.StarshipCrewClearPilot" }}"
                aria-label="{{ localize "SW5E.StarshipCrewClearPilot" }}"
              >
                <i class="fa-solid fa-user-slash" inert></i>
              </button>
            {{else}}
              <button
                type="button"
                class="sw5e-starship-item-button sw5e-starship-crew-icon-button"
                data-sw5e-crew-command="set-pilot"
                data-actor-uuid="{{uuid}}"
                title="{{ localize "SW5E.StarshipCrewSetPilot" }}"
                aria-label="{{ localize "SW5E.StarshipCrewSetPilot" }}"
              >
                <i class="fa-solid fa-user-check" inert></i>
              </button>
            {{/if}}
            <button
              type="button"
              class="sw5e-starship-item-button sw5e-starship-crew-icon-button"
              data-sw5e-crew-command="toggle-active"
              data-actor-uuid="{{uuid}}"
              title="{{#if active}}{{ localize "SW5E.StarshipCrewDeactivate" }}{{else}}{{ localize "SW5E.StarshipCrewActivate" }}{{/if}}"
              aria-label="{{#if active}}{{ localize "SW5E.StarshipCrewDeactivate" }}{{else}}{{ localize "SW5E.StarshipCrewActivate" }}{{/if}}"
            >
              {{#if active}}
              <i class="fa-solid fa-power-off" inert></i>
              {{else}}
              <i class="fa-solid fa-toggle-on" inert></i>
              {{/if}}
            </button>
            <button
              type="button"
              class="sw5e-starship-item-button sw5e-starship-crew-icon-button sw5e-starship-item-button-danger"
              data-sw5e-crew-command="remove"
              data-actor-uuid="{{uuid}}"
              title="{{ localize "SW5E.StarshipCrewRemove" }}"
              aria-label="{{ localize "SW5E.StarshipCrewRemove" }}"
            >
              <i class="fa-solid fa-user-xmark" inert></i>
            </button>
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <p class="sw5e-crew-empty">No crew assigned. Use "+ Add Crew Member" to assign crew.</p>
  {{/if}}
</div>
{{/inline}}

{{#*inline "sw5e-starship-crew-roles"}}
{{#if crewRoleGroups.length}}
<section class="sw5e-starship-crew-roles" aria-label="{{crewRolesTitle}}">
  <header class="sw5e-starship-section-header sw5e-starship-crew-roles-header">
    <div>
      <span class="sw5e-starship-kicker">{{crewRolesKicker}}</span>
      <h2>{{crewRolesTitle}}</h2>
      <p class="sw5e-starship-crew-roles-lede">{{crewRolesLede}}</p>
    </div>
  </header>
  <div class="sw5e-starship-groups sw5e-starship-groups-stacked items-list">
    {{#each crewRoleGroups}}
      <article class="sw5e-starship-group items-section card">
        <div class="items-header header sw5e-starship-group-header">
          <h3 class="item-name">
            <div class="name name-stacked">
              <span class="title">{{label}}</span>
              <span class="subtitle sw5e-starship-group-subtitle">Use the icon to roll or post to chat, open details when needed, or remove items directly from this tab.</span>
            </div>
          </h3>
          <div class="item-header sw5e-starship-sotg-group-actions always-visible">
            <div class="sw5e-starship-group-tools">
              <span class="sw5e-starship-group-count">{{count}}</span>
              {{#if supportsSheetNavigation}}
                <button
                  type="button"
                  class="sw5e-starship-group-link sw5e-starship-group-manage"
                  data-sw5e-action="open-tab"
                  data-first-item-id="{{firstItemId}}"
                >
                  Manage in {{manageLabel}}
                </button>
              {{/if}}
            </div>
          </div>
        </div>
        <ol class="item-list unlist sw5e-starship-item-list sw5e-starship-item-list--sotg">
          {{#each items}}
            {{> sw5e-sotg-item-row}}
          {{/each}}
        </ol>
      </article>
    {{/each}}
  </div>
</section>
{{/if}}
{{/inline}}

{{#*inline "sw5e-starship-core-repair"}}
<section class="sw5e-starship-core-repair-panel" aria-label="{{localize "SW5E.StarshipSheet.RepairActionsAria"}}">
  <div class="sw5e-starship-core-repair-actions">
    <button
      type="button"
      class="sw5e-starship-repair-action"
      data-sw5e-repair-action="recharge"
      title="{{localize "SW5E.RechargeRepair"}}"
      aria-label="{{localize "SW5E.RechargeRepair"}}"
    >{{localize "SW5E.Recharge"}}</button>
    <button
      type="button"
      class="sw5e-starship-repair-action"
      data-sw5e-repair-action="refitting"
      title="{{localize "SW5E.RefittingRepair"}}"
      aria-label="{{localize "SW5E.RefittingRepair"}}"
    >{{localize "SW5E.Refitting"}}</button>
    <button
      type="button"
      class="sw5e-starship-repair-action"
      data-sw5e-repair-action="regen"
      title="{{localize "SW5E.RegenRepair"}}"
      aria-label="{{localize "SW5E.RegenRepair"}}"
    >{{localize "SW5E.Regen"}}</button>
  </div>
</section>
{{/inline}}

{{#*inline "sw5e-starship-core-routing"}}
<section class="sw5e-starship-core-routing-panel sw5e-starship-system-path-scope" aria-label="{{systemsCore.labels.powerRouting}}">
  <div class="sw5e-starship-systems-field sw5e-starship-systems-field--routing-primary{{#unless @root.systemsRoutingEditable}} sw5e-starship-systems-field--locked{{/unless}}">
    <div class="sw5e-starship-systems-routing-heading">
      <label class="sw5e-starship-systems-routing-title" for="sw5e-core-routing">{{systemsCore.labels.powerRouting}}</label>
      <span class="sw5e-starship-systems-routing-badge" title="{{systemsCore.powerRoutingLegacyBadge}}">{{systemsCore.powerRoutingLegacyBadge}}</span>
    </div>
    <p class="notes sw5e-starship-systems-routing-hint">{{systemsCore.powerRoutingHint}}</p>
    <select
      id="sw5e-core-routing"
      class="sw5e-starship-systems-select sw5e-starship-systems-routing-select"
      name="system.attributes.power.routing"
      data-dtype="String"
      {{#unless @root.systemsRoutingEditable}}disabled{{/unless}}
    >
      {{#each systemsCore.routingOptions}}
      <option value="{{value}}" title="{{tooltip}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>
</section>
{{/inline}}

{{#*inline "sw5e-starship-core-fuel"}}
<section
  class="sw5e-starship-core-fuel-panel sw5e-starship-system-path-scope{{#if systemsCore.coreCollapse.fuel}} is-collapsed{{/if}}"
  aria-label="{{systemsCore.labels.fuel}}"
  data-sw5e-core-panel="fuel"
>
  <header class="sw5e-starship-core-fuel-header sw5e-starship-core-collapsible-header">
    <div class="sw5e-starship-core-fuel-heading sw5e-starship-core-collapsible-heading">
      <span class="sw5e-starship-systems-field-heading">{{systemsCore.labels.fuel}}</span>
    </div>
    <button
      type="button"
      class="sw5e-starship-core-fuel-collapse sw5e-starship-core-collapsible-toggle"
      data-sw5e-advanced-power-action="toggle-collapse"
      data-sw5e-core-collapse-action="toggle"
      data-core-panel="fuel"
      data-expand-label="{{systemsCore.coreCollapseLabels.fuel.expand}}"
      data-collapse-label="{{systemsCore.coreCollapseLabels.fuel.collapse}}"
      aria-expanded="{{#if systemsCore.coreCollapse.fuel}}false{{else}}true{{/if}}"
      title="{{#if systemsCore.coreCollapse.fuel}}{{systemsCore.coreCollapseLabels.fuel.expand}}{{else}}{{systemsCore.coreCollapseLabels.fuel.collapse}}{{/if}}"
      aria-label="{{#if systemsCore.coreCollapse.fuel}}{{systemsCore.coreCollapseLabels.fuel.expand}}{{else}}{{systemsCore.coreCollapseLabels.fuel.collapse}}{{/if}}"
    >
      <i class="fas fa-chevron-down" aria-hidden="true"></i>
    </button>
  </header>

  <div class="sw5e-starship-core-collapsible-body">
  <div class="sw5e-starship-systems-field sw5e-starship-systems-field--fuel{{#unless @root.systemsSetupEditable}} sw5e-starship-systems-field--locked{{/unless}}">

    <div class="sw5e-starship-fuel-capacity" aria-label="{{systemsCore.labels.fuelCapacity}}">
      <div class="sw5e-starship-fuel-track">
        <span class="sw5e-starship-fuel-fill" style="width: {{systemsCore.fuelPct}}%;"></span>
        <span class="sw5e-starship-fuel-breakpoint" data-pct="20" aria-hidden="true"></span>
        <span class="sw5e-starship-fuel-breakpoint" data-pct="40" aria-hidden="true"></span>
        <span class="sw5e-starship-fuel-breakpoint" data-pct="60" aria-hidden="true"></span>
        <span class="sw5e-starship-fuel-breakpoint" data-pct="80" aria-hidden="true"></span>
      </div>
      <span class="sw5e-starship-fuel-label">{{systemsCore.fuelBarLabel}}</span>
    </div>

    <div class="sw5e-starship-core-fuel-actions{{#unless @root.systemsRoutingEditable}} sw5e-starship-core-fuel-actions--locked{{/unless}}">
      <button
        type="button"
        class="sw5e-starship-fuel-action"
        data-sw5e-fuel-action="burn"
        title="{{systemsCore.labels.burnFuelTooltip}}"
        {{#unless @root.systemsRoutingEditable}}disabled{{/unless}}
      >{{systemsCore.labels.burnFuel}}</button>
      <button
        type="button"
        class="sw5e-starship-fuel-action"
        data-sw5e-fuel-action="refuel"
        title="{{systemsCore.labels.refuelTooltip}}"
        {{#unless @root.systemsRoutingEditable}}disabled{{/unless}}
      >{{systemsCore.labels.refuel}}</button>
    </div>

    <div class="sw5e-starship-systems-inline sw5e-starship-systems-inline--triple sw5e-starship-core-fuel-grid">
      <div class="sw5e-starship-systems-subfield">
        <label class="sw5e-starship-systems-label" for="sw5e-core-fuel-value">{{systemsCore.labels.fuelCurrent}}</label>
        <input
          id="sw5e-core-fuel-value"
          class="sw5e-starship-systems-input"
          type="number"
          name="system.attributes.fuel.value"
          value="{{systemsCore.fuelValue}}"
          min="0"
          step="1"
          data-dtype="Number"
          {{#unless @root.systemsSetupEditable}}disabled{{/unless}}
        />
      </div>
      <div class="sw5e-starship-systems-subfield">
        <label class="sw5e-starship-systems-label" for="sw5e-core-fuel-cap">{{systemsCore.labels.fuelCap}}</label>
        <input
          id="sw5e-core-fuel-cap"
          class="sw5e-starship-systems-input"
          type="number"
          name="system.attributes.fuel.fuelCap"
          value="{{systemsCore.fuelCap}}"
          min="0"
          step="1"
          data-dtype="Number"
          {{#unless @root.systemsSetupEditable}}disabled{{/unless}}
        />
      </div>
      <div class="sw5e-starship-systems-subfield">
        <label class="sw5e-starship-systems-label" for="sw5e-core-fuel-cost">{{systemsCore.labels.fuelCost}}</label>
        <input
          id="sw5e-core-fuel-cost"
          class="sw5e-starship-systems-input"
          type="number"
          name="system.attributes.fuel.cost"
          value="{{systemsCore.fuelCost}}"
          min="0"
          step="1"
          data-dtype="Number"
          {{#unless @root.systemsSetupEditable}}disabled{{/unless}}
        />
      </div>
    </div>
  </div>
  </div>
</section>
{{/inline}}

{{#*inline "sw5e-starship-core-advanced-power"}}
<section
  class="sw5e-starship-core-advanced-power-panel sw5e-starship-system-path-scope{{#if systemsCore.advancedPower.collapsed}} is-collapsed{{/if}}"
  aria-label="{{systemsCore.advancedPower.panelAria}}"
  data-sw5e-core-panel="advancedPower"
>
  <header class="sw5e-starship-core-advanced-power-header sw5e-starship-core-collapsible-header">
    <div class="sw5e-starship-core-advanced-power-heading sw5e-starship-core-collapsible-heading">
      <span class="sw5e-starship-systems-field-heading">{{systemsCore.advancedPower.title}}</span>
    </div>
    <button
      type="button"
      class="sw5e-starship-core-advanced-power-collapse sw5e-starship-core-collapsible-toggle"
      data-sw5e-advanced-power-action="toggle-collapse"
      data-sw5e-core-collapse-action="toggle"
      data-core-panel="advancedPower"
      data-expand-label="{{systemsCore.advancedPower.expandTooltip}}"
      data-collapse-label="{{systemsCore.advancedPower.collapseTooltip}}"
      aria-expanded="{{#if systemsCore.advancedPower.collapsed}}false{{else}}true{{/if}}"
      title="{{#if systemsCore.advancedPower.collapsed}}{{systemsCore.advancedPower.expandTooltip}}{{else}}{{systemsCore.advancedPower.collapseTooltip}}{{/if}}"
      aria-label="{{#if systemsCore.advancedPower.collapsed}}{{systemsCore.advancedPower.expandTooltip}}{{else}}{{systemsCore.advancedPower.collapseTooltip}}{{/if}}"
    >
      <i class="fas fa-chevron-down" aria-hidden="true"></i>
    </button>
  </header>

  <div class="sw5e-starship-core-advanced-power-body sw5e-starship-core-collapsible-body">
    <div class="sw5e-starship-advanced-power-die-row{{#unless @root.systemsSetupEditable}} sw5e-starship-systems-field--locked{{/unless}}">
      <span class="sw5e-starship-advanced-power-die-label">{{systemsCore.advancedPower.dieLabel}}</span>
      {{#if @root.systemsSetupEditable}}
      <select
        id="sw5e-core-power-die"
        class="sw5e-starship-systems-select sw5e-starship-advanced-power-die-select"
        name="system.attributes.power.die"
        data-dtype="String"
      >
        {{#each systemsCore.advancedPower.dieOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{value}}</option>
        {{/each}}
      </select>
      {{else}}
      <span class="sw5e-starship-advanced-power-die-value">{{systemsCore.advancedPower.dieDisplay}}</span>
      {{/if}}
    </div>

    <div class="sw5e-starship-core-advanced-power-actions{{#unless @root.systemsRoutingEditable}} sw5e-starship-core-advanced-power-actions--locked{{/unless}}">
      <button
        type="button"
        class="sw5e-starship-advanced-power-recover"
        data-sw5e-advanced-power-action="recover"
        data-can-recover="{{#if systemsCore.advancedPower.canRecover}}1{{else}}0{{/if}}"
        title="{{systemsCore.advancedPower.recoverTooltip}}"
        {{#unless @root.systemsRoutingEditable}}disabled{{/unless}}
        {{#unless systemsCore.advancedPower.canRecover}}disabled{{/unless}}
      >{{systemsCore.advancedPower.recoverLabel}}</button>
    </div>

    <div class="sw5e-starship-advanced-power-slots" role="list" aria-label="{{systemsCore.advancedPower.panelAria}}">
      {{#each systemsCore.advancedPower.slots}}
      <div class="sw5e-starship-advanced-power-slot{{#if isCentral}} is-central{{/if}}{{#if @root.systemsSetupEditable}} sw5e-starship-advanced-power-slot--edit{{/if}}" role="listitem">
        <span class="sw5e-starship-advanced-power-slot-label">{{label}}</span>
        {{#if @root.systemsSetupEditable}}
        <div class="sw5e-starship-advanced-power-slot-field">
          <label class="sw5e-starship-systems-label" for="sw5e-core-power-{{key}}-value">{{@root.systemsCore.advancedPower.currentLabel}}</label>
          <input
            id="sw5e-core-power-{{key}}-value"
            class="sw5e-starship-systems-input sw5e-starship-advanced-power-input"
            type="number"
            name="system.attributes.power.{{key}}.value"
            value="{{value}}"
            min="0"
            step="1"
            data-dtype="Number"
          />
        </div>
        <div class="sw5e-starship-advanced-power-slot-field">
          <label class="sw5e-starship-systems-label" for="sw5e-core-power-{{key}}-max">{{@root.systemsCore.advancedPower.maxLabel}}</label>
          <input
            id="sw5e-core-power-{{key}}-max"
            class="sw5e-starship-systems-input sw5e-starship-advanced-power-input"
            type="number"
            name="system.attributes.power.{{key}}.max"
            value="{{storedMax}}"
            min="0"
            step="1"
            data-dtype="Number"
          />
        </div>
        {{#if maxDisplayDiffers}}
        <span class="sw5e-starship-advanced-power-max-hint" role="note">{{maxDisplayHint}}</span>
        {{/if}}
        {{else}}
        <span class="sw5e-starship-advanced-power-slot-value">{{displayValue}} / {{displayMax}}</span>
        <div class="sw5e-starship-core-advanced-power-actions sw5e-starship-core-advanced-power-actions--slot{{#unless @root.systemsRoutingEditable}} sw5e-starship-core-advanced-power-actions--locked{{/unless}}">
          <button
            type="button"
            class="sw5e-starship-advanced-power-spend"
            data-sw5e-advanced-power-action="spend"
            data-power-slot="{{key}}"
            title="{{@root.systemsCore.advancedPower.spendTooltip}}"
            {{#unless canSpend}}disabled{{/unless}}
            {{#unless @root.systemsRoutingEditable}}disabled{{/unless}}
          >{{@root.systemsCore.advancedPower.spendLabel}}</button>
        </div>
        {{/if}}
      </div>
      {{/each}}
    </div>

  </div>
</section>
{{/inline}}

<section class="sw5e-starship-panel" data-application-part="sw5e-starship-sotg">
  <div class="sw5e-starship-main-body">
    <section class="sw5e-starship-sotg-panel active" data-sw5e-sotg-panel="overview" role="tabpanel" id="sw5e-sotg-panel-overview">
      {{#if overviewAbilities.length}}
        <section class="sw5e-starship-overview-dashboard" aria-label="{{overviewAbilitiesAriaLabel}}">
          <div class="sw5e-starship-overview-abilities-row">
            <div class="middle ability-scores card flexrow sw5e-starship-ability-strip" role="list">
              {{#each overviewAbilities}}
              <div class="ability-score sw5e-starship-ability-tile" data-ability="{{key}}" title="{{label}}">
                <img src="{{abilityIcon}}" alt="{{label}}">
                <a
                  class="label rollable ability-check"
                  data-action="roll"
                  data-type="ability"
                  data-sw5e-action="roll-ability"
                  data-ability="{{key}}"
                  title="{{ localize "SW5E.AbilityPromptTitle" ability=label }}"
                  aria-label="{{ localize "SW5E.AbilityPromptTitle" ability=label }}"
                >{{abbrLower}}</a>
                <div class="mod">
                  {{#if @root.sotgSheetEditMode}}
                  <button
                    type="button"
                    class="config-button unbutton"
                    data-action="showConfiguration"
                    data-config="ability"
                    data-tooltip="{{configureLabel}}"
                    aria-label="{{configureLabel}}"
                  >
                    <i class="fas fa-cog" inert></i>
                  </button>
                  {{else}}
                  <span class="sign">{{modSign}}</span>{{modAbs}}
                  {{/if}}
                </div>
                <div class="score">
                  {{#if @root.sotgSheetEditMode}}
                  <input
                    type="text"
                    name="{{inputName}}"
                    value="{{sourceValue}}"
                    placeholder="10"
                    data-dtype="Number"
                    class="uninput"
                    data-sw5e-overview-edit-ability="{{key}}"
                    data-sw5e-overview-input-name="{{inputName}}"
                  >
                  {{else}}
                  {{value}}
                  {{/if}}
                </div>
                <div
                  class="save-tab saving-throw{{#unless @root.sotgSheetEditMode}} rollable{{/unless}}"
                  {{#unless @root.sotgSheetEditMode}}
                  data-action="roll"
                  data-type="ability"
                  data-sw5e-action="roll-save"
                  data-ability="{{key}}"
                  data-tooltip="{{saveRollTooltip}}"
                  aria-label="{{saveRollTooltip}}"
                  {{else}}
                  data-tooltip="{{hover}}"
                  {{/unless}}
                >
                  <proficiency-cycle
                    type="ability"
                    name="{{proficientName}}"
                    data-tooltip="{{hover}}"
                    aria-label="{{hover}}"
                    value="{{proficient}}"
                    {{#unless @root.sotgSheetEditMode}}disabled{{/unless}}
                  ></proficiency-cycle>
                  <span class="save">{{numberFormat save decimals=0 sign=true}}</span>
                  <i class="fas fa-shield-heart" inert></i>
                </div>
              </div>
              {{/each}}
            </div>
          </div>

          <div class="sw5e-starship-overview-main">
            {{#if skills.length}}
            <section class="sw5e-starship-overview-skills" aria-label="{{overviewSkillsAriaLabel}}">
              <header class="sw5e-starship-overview-skills-header">
                <div>
                  <span class="sw5e-starship-kicker">{{overviewSkillsKicker}}</span>
                </div>
              </header>
              <ul class="sw5e-starship-skill-list sw5e-starship-skill-list--pc" role="list">
                {{#each skills}}
                <li class="sw5e-starship-skill-row sw5e-starship-skill-row--pc{{proficiencyClass}}" data-skill-id="{{id}}">
                  <button
                    type="button"
                    class="sw5e-starship-skill-roll-area"
                    data-sw5e-action="roll-skill"
                    data-skill-id="{{id}}"
                    aria-label="{{ localize "DND5E.Roll" }} {{label}}"
                  >
                    <span class="sw5e-starship-skill-prof" aria-hidden="true">{{{icon}}}</span>
                    <span class="sw5e-starship-skill-ability-abbr">{{abilityAbbr}}</span>
                    <span class="sw5e-starship-skill-label">{{label}}</span>
                    <span class="sw5e-starship-skill-mod">{{modDisplay}}</span>
                    <span class="sw5e-starship-skill-passive">{{#if passiveDisplay}}{{passiveDisplay}}{{else}}—{{/if}}</span>
                  </button>
                  {{#if ../editable}}
                  <button
                    type="button"
                    class="sw5e-starship-skill-config sw5e-starship-skill-config--edit-only"
                    data-sw5e-action="configure-skill"
                    data-skill-id="{{id}}"
                    title="{{../overviewSkillConfigureTitle}}"
                    aria-label="{{../overviewSkillConfigureTitle}}: {{label}}"
                  >
                    <i class="fas fa-cog" aria-hidden="true"></i>
                  </button>
                  {{/if}}
                </li>
                {{/each}}
              </ul>
            </section>
            {{/if}}

            <div class="sw5e-starship-overview-operations">
              {{> sw5e-starship-core-repair}}
              {{#if crew}}
              <section
                class="sw5e-starship-crew-panel{{#if systemsCore.coreCollapse.crew}} is-collapsed{{/if}}"
                aria-label="Crew &amp; Passengers"
                data-sw5e-core-panel="crew"
              >
                <header class="sw5e-starship-core-crew-header sw5e-starship-core-collapsible-header">
                  <div class="sw5e-starship-core-crew-heading sw5e-starship-core-collapsible-heading">
                    <span class="sw5e-starship-systems-field-heading">Crew &amp; Passengers</span>
                  </div>
                  <div class="sw5e-starship-core-collapsible-header-actions">
                    <button
                      type="button"
                      class="sw5e-starship-item-button sw5e-starship-crew-add sw5e-starship-crew-icon-button"
                      data-sw5e-crew-command="open-add-crew"
                      title="{{ localize "SW5E.StarshipCrewAdd" }}"
                      aria-label="{{ localize "SW5E.StarshipCrewAdd" }}"
                    >
                      <i class="fa-solid fa-user-plus" inert></i>
                    </button>
                    <button
                      type="button"
                      class="sw5e-starship-core-crew-collapse sw5e-starship-core-collapsible-toggle"
                      data-sw5e-advanced-power-action="toggle-collapse"
                      data-sw5e-core-collapse-action="toggle"
                      data-core-panel="crew"
                      data-expand-label="{{systemsCore.coreCollapseLabels.crew.expand}}"
                      data-collapse-label="{{systemsCore.coreCollapseLabels.crew.collapse}}"
                      aria-expanded="{{#if systemsCore.coreCollapse.crew}}false{{else}}true{{/if}}"
                      title="{{#if systemsCore.coreCollapse.crew}}{{systemsCore.coreCollapseLabels.crew.expand}}{{else}}{{systemsCore.coreCollapseLabels.crew.collapse}}{{/if}}"
                      aria-label="{{#if systemsCore.coreCollapse.crew}}{{systemsCore.coreCollapseLabels.crew.expand}}{{else}}{{systemsCore.coreCollapseLabels.crew.collapse}}{{/if}}"
                    >
                      <i class="fas fa-chevron-down" aria-hidden="true"></i>
                    </button>
                  </div>
                </header>
                <div class="sw5e-starship-core-collapsible-body">
                {{> sw5e-starship-crew-management}}
                {{> sw5e-starship-crew-roles}}
                </div>
              </section>
              {{/if}}
              {{#if showPowerRouting}}
              {{> sw5e-starship-core-routing}}
              {{/if}}
              {{> sw5e-starship-core-advanced-power}}
              {{> sw5e-starship-core-fuel}}
            </div>
          </div>
        </section>
        {{/if}}
    </section>
  </div>
</section>
